{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(npm run build:*)",
      "Bash(npm test:*)",
      "Bash(pytest:*)",
      "Bash(python -m compileall:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout --:*)",
      "Bash(printenv:*)",
      "Bash(env:*)",
      "Bash(curl *|*sh:*)",
      "Bash(wget *|*sh:*)"
    ]
  }
}

