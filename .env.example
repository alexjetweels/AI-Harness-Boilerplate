# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by FastAPI backend)
DATABASE_URL=postgresql://harness:harness_dev@localhost:5433/harness

# ── Harness subprocess logging ─────────────────────────────────────────────────
# Set automatically by backend when launching harness subprocess.
# You can set it manually for CLI runs to get DB logging.
# HARNESS_DB_URL=postgresql://harness:harness_dev@localhost:5432/harness
