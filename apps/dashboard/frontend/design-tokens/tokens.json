    "scale": {
      "displayLarge": {
        "fontSize": "57px",
        "lineHeight": "64px",
        "fontWeight": 400,
        "letterSpacing": "-0.25px"
      },
      "displayMedium": {
        "fontSize": "45px",
        "lineHeight": "52px",
        "fontWeight": 400,
        "letterSpacing": "0px"
      },
      "displaySmall": {
        "fontSize": "36px",
        "lineHeight": "44px",
        "fontWeight": 400,
        "letterSpacing": "0px"
      },
      "headlineLarge": {
