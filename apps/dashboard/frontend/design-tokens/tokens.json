  "state": {
    "hoverOpacity": "0.08",
    "focusOpacity": "0.12",
    "pressedOpacity": "0.12",
    "draggedOpacity": "0.16",
    "disabledContentOpacity": "0.38",
    "disabledContainerOpacity": "0.12"
  },
  "breakpoint": {
    "compact": "0px",
    "medium": "600px",
    "expanded": "840px",
    "large": "1200px",
    "extraLarge": "1600px"
  },
  "zIndex": {
    "base": 0,
    "dropdown": 1000,
    "sticky": 1100,
    "modal": 1300,
    "popover": 1400,
    "toast": 1500,
    "tooltip": 1600
  }
