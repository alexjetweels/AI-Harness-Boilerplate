      "bodySmall": {
        "fontSize": "12px",
        "lineHeight": "16px",
        "fontWeight": 400,
        "letterSpacing": "0.4px"
      },
      "labelLarge": {
        "fontSize": "14px",
        "lineHeight": "20px",
        "fontWeight": 500,
        "letterSpacing": "0.1px"
      },
      "labelMedium": {
        "fontSize": "12px",
        "lineHeight": "16px",
        "fontWeight": 500,
        "letterSpacing": "0.5px"
